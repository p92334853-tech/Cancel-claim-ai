{
  "name": "cancel-claim-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Cancel & Claim AI — a premium AI assistant that helps people cancel subscriptions, request refunds, and prepare disputes, complaints, and appeals.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @cancelclaim/web dev",
    "build": "pnpm --filter @cancelclaim/web build",
    "start": "pnpm --filter @cancelclaim/web start",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm --filter @cancelclaim/core test",
    "db:generate": "pnpm --filter @cancelclaim/web db:generate",
    "db:push": "pnpm --filter @cancelclaim/web db:push",
    "mobile": "pnpm --filter @cancelclaim/mobile start"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
