# ---------------------------------------------------------------------------
# Cancel & Claim AI — web environment
# Copy to .env.local for local development. Every external integration is
# OPTIONAL: with none set, the app runs fully on the deterministic engine,
# local SQLite, and dev-mode payments.
# ---------------------------------------------------------------------------

# Database -------------------------------------------------------------------
# sqlite (default, zero-setup local dev) or postgresql (production)
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"
# Production example:
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://user:pass@host:5432/cancelclaim?schema=public"

# Session security -----------------------------------------------------------
# Used to sign anonymous session cookies. Generate: openssl rand -base64 32
SESSION_SECRET="dev-insecure-change-me-please-0000000000000000"

# AI provider (optional) -----------------------------------------------------
# Leave unset to use the built-in deterministic engine. Set to enable Claude.
ANTHROPIC_API_KEY=""
AI_MODEL="claude-sonnet-4-6"

# Payments (optional) --------------------------------------------------------
# Leave unset for dev-mode entitlements (instant unlock, no charge).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_SINGLE=""
STRIPE_PRICE_BUNDLE=""
STRIPE_PRICE_PRO=""

# Public config --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_ANALYTICS_ENABLED="false"

# Object storage (optional, for production evidence uploads) ------------------
# v1 stores small evidence text inline; wire S3-compatible storage for files.
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
